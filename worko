#!/usr/bin/env bash
# worko —— gateway 控制 + 提问 的薄壳。
#   worko start          后台起 daemon（长连 hub，等别人来问你），不挡 agent 交互
#   worko stop           停掉 daemon
#   worko status         看 daemon 在不在
#   worko logs           跟 daemon 日志
#   worko ask <who> <问题>   向某个 agent 提问，阻塞到拿回答（不碰 daemon）
#
# 配置来源：环境变量优先，其次 ~/.worko/config（KEY=value 行）。
set -euo pipefail

# —— 读配置 ——
CONFIG="${WORKO_CONFIG:-$HOME/.worko/config}"
# shellcheck disable=SC1090
[ -f "$CONFIG" ] && . "$CONFIG"

WORKO_URL="${WORKO_URL:-http://localhost:8080}"
WORKO_ID="${WORKO_ID:-}"
WORKO_TOKEN="${WORKO_TOKEN:-}"
WORKO_AGENT="${WORKO_AGENT:-claude}"   # 被问到时用哪个本地 agent 答：claude | codex | mock

# client.ts 默认在本脚本同目录
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLIENT="${WORKO_CLIENT:-$HERE/client.ts}"

RUNDIR="${WORKO_RUNDIR:-$HOME/.worko/run}"
mkdir -p "$RUNDIR"
PIDFILE="$RUNDIR/${WORKO_ID:-default}.pid"
LOGFILE="$RUNDIR/${WORKO_ID:-default}.log"

need_id() {
  [ -n "$WORKO_ID" ] || { echo "需要 WORKO_ID（在 $CONFIG 或环境变量里设）" >&2; exit 1; }
}
is_running() { [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; }

cmd="${1:-}"; shift || true
case "$cmd" in
  start)
    need_id
    if is_running; then echo "[worko] daemon 已在跑 (pid=$(cat "$PIDFILE"))"; exit 0; fi
    # 顺手探一下 hub 通不通（不致命）
    curl -fsS -m 3 "$WORKO_URL/health" >/dev/null 2>&1 || echo "[worko] 警告：$WORKO_URL 暂时连不上，daemon 会自动重连"
    echo "[worko] 启动 daemon: id=$WORKO_ID agent=$WORKO_AGENT url=$WORKO_URL"
    WORKO_ID="$WORKO_ID" WORKO_TOKEN="$WORKO_TOKEN" WORKO_URL="$WORKO_URL" WORKO_AGENT="$WORKO_AGENT" \
      nohup node "$CLIENT" >"$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    echo "[worko] 后台运行 pid=$(cat "$PIDFILE")  日志: worko logs"
    ;;
  stop)
    if is_running; then kill "$(cat "$PIDFILE")" && rm -f "$PIDFILE" && echo "[worko] 已停止";
    else echo "[worko] 没在跑"; rm -f "$PIDFILE" 2>/dev/null || true; fi
    ;;
  status)
    if is_running; then echo "[worko] running  pid=$(cat "$PIDFILE")  id=$WORKO_ID  url=$WORKO_URL";
    else echo "[worko] stopped  id=${WORKO_ID:-?}"; fi
    ;;
  logs)
    [ -f "$LOGFILE" ] || { echo "还没有日志（先 worko start）" >&2; exit 1; }
    tail -f "$LOGFILE"
    ;;
  ask)
    need_id
    to="${1:-}"; shift || true
    [ -n "$to" ] && [ -n "${1:-}" ] || { echo "用法: worko ask <对方id> <问题>" >&2; exit 1; }
    WORKO_ID="$WORKO_ID" WORKO_TOKEN="$WORKO_TOKEN" WORKO_URL="$WORKO_URL" \
      node "$CLIENT" ask "$to" "$*"
    ;;
  ""|-h|--help|help)
    echo "用法: worko {start|stop|status|logs|ask <who> <问题>}"
    ;;
  *)
    echo "未知命令: $cmd" >&2; echo "用法: worko {start|stop|status|logs|ask <who> <问题>}" >&2; exit 1
    ;;
esac
