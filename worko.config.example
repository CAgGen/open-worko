# Copy to ~/.worko/config (or override with environment variables). All worko commands read this file.
# These values typically come from an invite sent to you by a teammate.

WORKO_URL=http://localhost:8080      # Hub address (use the internal IP for a corporate network)
WORKO_ID=alice@corp.com              # Your identity — the handle others use to @ you (email recommended)
WORKO_TOKEN=dev-secret               # Shared token to access this workspace
WORKO_AGENT=claude                   # Local agent to use when queried: claude | codex
# WORKO_ROOM is not required: init fetches the room id from the hub using your token and writes it automatically.
# If it can't be fetched, leave it empty — the server falls back to token-based room resolution at send time.
